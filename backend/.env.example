# ===========================================================================
#  Zugangsdaten für den gesamten Stack. Datei nach ".env" kopieren und ausfüllen.
#  WICHTIG: Diese Werte werden beim ALLERERSTEN Start von InfluxDB festgeschrieben.
#  Spätere Änderungen hier wirken NICHT rückwirkend (dann Volume neu anlegen).
# ===========================================================================

# InfluxDB-Admin-Login (Web-UI unter http://<LXC-IP>:8086, falls Port geöffnet)
INFLUX_USERNAME=admin
INFLUX_PASSWORD=BITTE-AENDERN-min-8-Zeichen

# Organisation + Bucket (Standard so lassen ist ok)
INFLUX_ORG=energy
INFLUX_BUCKET=readings

# Admin-Token – NEU erzeugen mit:   openssl rand -hex 32
INFLUX_TOKEN=BITTE-AENDERN-openssl-rand-hex-32
